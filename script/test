#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT_DIR"

echo "Running script/test"

"$ROOT_DIR/script/bootstrap"
eval "$(mise activate bash)" 2>/dev/null || true

echo "Running JavaScript unit tests with coverage..."
pnpm --filter running-challenges-tests run test-with-coverage

if [[ -d "browser-extensions/extension/src/js/tests/ui-test" ]]; then
  echo "Running Playwright UI tests..."
  UI_TEST_DIR="browser-extensions/extension/src/js/tests/ui-test"
  EXT_UNPACKED="$UI_TEST_DIR/extension-binaries/chrome-extension-package"
  if [[ ! -f "$EXT_UNPACKED/manifest.json" ]]; then
    echo "Chrome extension not unpacked; building and unpacking..."
    pnpm --filter running-challenges-extension run build:extension
    mkdir -p "$EXT_UNPACKED"
    unzip -o browser-extensions/chrome/build/web-ext-artifacts/running_challenges-chrome-*.zip -d "$EXT_UNPACKED"
  fi
  pnpm --filter running-challenges-chrome-ui-testing run test
fi

