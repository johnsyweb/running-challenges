#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT_DIR"

echo "Running script/test"

"$ROOT_DIR/script/bootstrap"

if [[ -d "browser-extensions/extension/src/js/tests" ]]; then
  cd browser-extensions/extension/src/js/tests
  echo "Running JavaScript unit tests with coverage..."
  npm run test-with-coverage
else
  echo "No JavaScript tests directory found at browser-extensions/extension/src/js/tests" >&2
  exit 1
fi

