#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT_DIR"

echo "Running script/update-screenshots"

# Ensure Chrome extension is built (used to load the extension when capturing)
if [[ ! -f browser-extensions/chrome/build/manifest.json ]]; then
  echo "Chrome extension not built. Run ./script/update first."
  exit 1
fi

cd "$ROOT_DIR/browser-extensions/extension/src/js/tests/ui-test"
node scripts/capture-website-screenshots.cjs

echo "Screenshot(s) written to $ROOT_DIR/images/screenshots/"
