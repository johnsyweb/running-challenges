#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT_DIR"

echo "Running script/bootstrap"

# Ensure mise is available so we can install the toolchain from mise.toml
if ! command -v mise >/dev/null 2>&1; then
  if [[ -x "${HOME}/.local/bin/mise" ]]; then
    export PATH="${HOME}/.local/bin:${PATH}"
  else
    echo "mise is required to install the dev toolchain (Node.js, pnpm, Ruby)." >&2
    echo "Install it from: https://mise.jdx.dev" >&2
    exit 1
  fi
fi

# Install dev tools from mise.toml (node, pnpm, ruby, etc.)
if [[ -f "mise.toml" ]]; then
  echo "Installing dev tools with mise..."
  mise install
  eval "$(mise activate bash)" 2>/dev/null || true
fi

# Install extension build dependencies via pnpm when in a pnpm workspace
if [[ -f "pnpm-workspace.yaml" ]] && command -v pnpm >/dev/null 2>&1; then
  echo "Installing extension dependencies with pnpm..."
  pnpm install
fi

# Ensure web-ext is available for building and running the extensions
if ! command -v web-ext >/dev/null 2>&1; then
  echo "web-ext not found, installing it globally with pnpm..."
  pnpm add -g web-ext
fi

# Ensure GNU sed is available on macOS, as required by the build scripts
if [[ "${OSTYPE:-}" == darwin* ]]; then
  if ! command -v gsed >/dev/null 2>&1; then
    echo "gnu-sed (gsed) is required for extension builds on macOS." >&2
    echo "Install it with: brew install gnu-sed" >&2
    exit 1
  fi
fi

echo "script/bootstrap completed successfully."

