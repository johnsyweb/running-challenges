#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT_DIR"

DEFAULT_PARKRUN_URL="https://www.parkrun.com.au/parkrunner/100388/all"

REQUESTED_URL="${1:-${PARKRUN_URL:-$DEFAULT_PARKRUN_URL}}"

echo "Running script/server"
echo "Target parkrun URL: ${REQUESTED_URL}"

"$ROOT_DIR/script/update"

cd "$ROOT_DIR/browser-extensions/firefox/build"

echo "Starting Firefox with web-ext..."
exec web-ext run -v -u "${REQUESTED_URL}"

